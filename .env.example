# JFrog Artifactory credentials (used by bootstrap and mcp-server)
ARTIFACTORY_USER=admin
ARTIFACTORY_PASSWORD=password
ARTIFACTORY_URL=http://localhost:8082

# Anthropic API key (required for the discovery agent)
ANTHROPIC_API_KEY=sk-ant-...

# MCP server URL (used by the discovery agent)
MCP_SERVER_URL=http://localhost:3000
